# VisionGrid Environment Configuration
# Copy this file to .env and modify as needed

# Server
VISIONGRID_SERVER__HOST=0.0.0.0
VISIONGRID_SERVER__PORT=8000

# Detection
VISIONGRID_DETECTION__MODEL=yolov8n
VISIONGRID_DETECTION__DEVICE=cpu
VISIONGRID_DETECTION__CONFIDENCE=0.5

# Database
VISIONGRID_DATABASE__URL=sqlite+aiosqlite:///./visiongrid.db

# Redis (optional, for distributed deployments)
VISIONGRID_REDIS__ENABLED=false
VISIONGRID_REDIS__URL=redis://localhost:6379/0

# Logging
VISIONGRID_LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
